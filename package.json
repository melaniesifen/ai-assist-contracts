{
  "name": "@ai-assist/contracts",
  "version": "0.1.0",
  "description": "Shared dependency-light contracts for the AI Assist Platform MVP.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./actions": "./src/actions.js",
    "./auth": "./src/auth.js",
    "./commands": "./src/commands.js",
    "./connectors": "./src/connectors.js",
    "./context": "./src/context.js",
    "./errors": "./src/errors.js",
    "./events": "./src/events.js",
    "./fixtures/assistant-stream": "./fixtures/assistant-stream.fixtures.js",
    "./fixtures/google-docs-read-path": "./fixtures/google-docs-read-path.fixtures.js",
    "./fixtures/m1-google-docs-vertical-slice": "./fixtures/m1-google-docs-vertical-slice.fixtures.js",
    "./fixtures/m3-first-run-setup": "./fixtures/m3-first-run-setup.fixtures.js",
    "./fixtures/proposed-actions": "./fixtures/proposed-actions.fixtures.js",
    "./identity": "./src/identity.js",
    "./logging": "./src/logging.js",
    "./providers": "./src/providers.js",
    "./secrets": "./src/secrets.js",
    "./setup": "./src/setup.js",
    "./validation": "./src/validation.js",
    "./versioning": "./src/versioning.js"
  },
  "files": [
    "docs",
    "fixtures",
    "model",
    "smithy-build.json",
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "coverage": "node --experimental-test-coverage --test",
    "smithy:validate": "smithy validate model",
    "smithy:build": "smithy build --config smithy-build.json --output build/smithy"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}
